# ── 앱 설정 ───────────────────────────────────────────
APP_NAME="ExcuseMe API"
DEBUG=True

# ── 데이터베이스 ───────────────────────────────────────
# MySQL 사용 시
DATABASE_URL=mysql+pymysql://USER:PASSWORD@localhost:3306/excuseme

# SQLite 로컬 테스트 시 (MySQL 없을 때 임시 사용)
# DATABASE_URL=sqlite:///./excuseme.db

# ── Google OAuth ───────────────────────────────────────
# Google Cloud Console > API 및 서비스 > 사용자 인증 정보에서 발급
# https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# 승인된 리디렉션 URI에 반드시 동일한 값을 등록해야 함
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ── JWT ────────────────────────────────────────────────
# openssl rand -hex 32 로 생성 권장
JWT_SECRET_KEY=change-me-to-a-strong-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── GPT API ────────────────────────────────────────────
GPT_API_KEY=sk-proj-...

# ── CORS ───────────────────────────────────────────────
# 쉼표로 구분해서 여러 오리진 허용 가능
# 예: ALLOWED_ORIGINS=["http://localhost:3000","https://yourdomain.com"]
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]
